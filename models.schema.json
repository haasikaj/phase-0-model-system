{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["models"],
  "properties": {
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "provider",
          "tier",
          "status",
          "pricing",
          "specs",
          "context_profile",
          "best_for"
        ],
        "properties": {
          "id": { "type": "string" },

          "provider": { "type": "string" },

          "tier": {
            "type": "string",
            "enum": ["fast", "standard", "powerful"]
          },

          "status": {
            "type": "string",
            "enum": ["active", "preview", "deprecated"]
          },

          "pricing": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input", "output"],
            "properties": {
              "input": { "type": "number" },
              "output": { "type": "number" }
            }
          },

          "specs": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "max_output_tokens",
              "supports_images",
              "supports_tools",
              "supports_reasoning"
            ],
            "properties": {
              "max_output_tokens": { "type": "integer" },
              "supports_images": { "type": "boolean" },
              "supports_tools": { "type": "boolean" },
              "supports_reasoning": { "type": "boolean" }
            }
          },

          "context_profile": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "native_window",
              "effective_window",
              "memory_budget_tokens",
              "compaction_floor"
            ],
            "properties": {
              "native_window": { "type": "integer" },
              "effective_window": { "type": "integer" },
              "memory_budget_tokens": { "type": "integer" },
              "compaction_floor": { "type": "number" }
            }
          },

          "best_for": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}